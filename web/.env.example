# web/.env.example - Frontend environment variables
# Copy to web/.env.local for local dev: cp .env.example .env.local
# For Firebase deployment, set these as Firebase environment config or bake them in at build time.
# Vite exposes VITE_* vars to the browser at build time (they are baked into the JS bundle).
# Do NOT put secrets here that should stay secret - API_KEY is low-stakes but still.

# URL of the SignalFlow backend API (your Pi's address + port)
# For local dev this is probably localhost:3001
# For production this is your Pi's public IP or domain
VITE_API_URL=http://localhost:3001

# Shared secret for mutation endpoints (restart, add/remove symbols)
# Must match API_KEY in the backend .env on your Pi
VITE_API_KEY=change_me_to_a_random_secret
