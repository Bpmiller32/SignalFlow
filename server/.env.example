# SignalFlow Environment Configuration
# Copy this to .env and fill in your values: cp .env.example .env

MODE=PAPER

# Alpaca API (https://app.alpaca.markets)
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET_KEY=your_alpaca_secret_key
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Discord Bot (https://discord.com/developers/applications)
DISCORD_BOT_TOKEN=your_bot_token
DISCORD_GUILD_ID=your_server_id

# Channel ID for bot notifications (right-click channel → Copy Channel ID, requires Developer Mode)
DISCORD_CHANNEL_ID=

# Logging
LOG_LEVEL=normal

# Web Dashboard API (web/ frontend)
# API_PORT is the port the REST API listens on (default 3001)
# API_KEY is a shared secret for mutation endpoints (restart, add/remove symbols)
# Make up any string you want - just keep it out of git
API_PORT=3001
API_KEY=change_me_to_a_random_secret
