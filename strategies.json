{
  "strategies": [
    {
      "id": "orb-fvg-default",
      "type": "opening-range-breakout",
      "enabled": true,
      "symbols": ["SPY", "AAPL", "MSFT", "NVDA", "GOOGL", "META", "GME"],
      "maxTradesPerDay": 2,
      "holdOvernight": false,

      "schedule": {
        "sessionSetupEnd": "09:35",
        "tradingCutoff": "11:30",
        "marketClose": "16:00",
        "pollingIntervalMs": 10000,
        "maxStaleDataMinutes": 2
      },

      "notifications": {
        "trades": "DISCORD_CHANNEL_TRADES",
        "system": "DISCORD_CHANNEL_SYSTEM",
        "errors": "DISCORD_CHANNEL_ERRORS"
      },

      "params": {
        "inverseMode": true,
        "openingRange": {
          "minSize": 0.10,
          "maxSize": 2.0,
          "minStrength": 3.0,
          "maxPremarketGap": 3.0,
          "skipEarningsDays": true
        },
        "breakout": {
          "volumeMultiplier": 1.2,
          "minAbsoluteVolume": 5000,
          "maxFvgWindowMinutes": 15
        },
        "fvg": {
          "bodyPercent": 40,
          "minRangePercent": 0.08,
          "overlapTolerance": 2.0,
          "closePositionPercent": 35,
          "requireVolumeConfirmation": false,
          "volumeMultiplier": 1.0
        },
        "positionSizing": {
          "mode": "FIXED",
          "fixedSize": 1000,
          "accountRiskPercent": 1.0,
          "maxValue": 10000,
          "minValue": 100,
          "useAdaptive": true,
          "weakSignalSizePercent": 75
        },
        "riskManagement": {
          "riskRewardRatio": 2.0,
          "stopLossBufferPercent": 0.05,
          "useAtrStops": false,
          "atrPeriod": 14,
          "atrStopMultiplier": 1.5,
          "useTrailingStops": true,
          "trailingStopActivation": 1.0,
          "trailingStopAtrMultiple": 1.5,
          "usePartialExits": true,
          "partialExitAtRMultiple": 1.0,
          "partialExitPercent": 50
        }
      }
    }
  ]
}
