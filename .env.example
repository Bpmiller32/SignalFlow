# SignalFlow Environment Configuration
# Copy this to .env and fill in your values: cp .env.example .env

# Mode: PAPER (simulated) or LIVE (real money - not implemented yet)
MODE=PAPER

# Alpaca API credentials (get from https://app.alpaca.markets)
# Paper trading uses paper-api URL, live uses api URL
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Discord webhook URLs (create in Discord channel settings → Integrations → Webhooks)
# Each webhook posts to a different channel
DISCORD_WEBHOOK_TRADES=https://discord.com/api/webhooks/your_trades_webhook
DISCORD_WEBHOOK_SYSTEM=https://discord.com/api/webhooks/your_system_webhook
DISCORD_WEBHOOK_ERRORS=https://discord.com/api/webhooks/your_errors_webhook

# Logging: "normal" or "debug" (debug shows all candle/filter details)
LOG_LEVEL=normal
